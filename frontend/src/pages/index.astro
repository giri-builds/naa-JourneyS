---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import ChatWidget from '../components/ChatWidget.astro';
import { getCollection } from 'astro:content';

const sections = await getCollection('journey');
const sorted = sections.sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Home">
  <section class="py-20 md:py-28">
    <h1 class="text-5xl font-bold leading-tight tracking-tight md:text-7xl">
      <span class="text-white">naa-</span><span class="bg-gradient-to-r from-accent to-accent-2 bg-clip-text text-transparent">JourneyS</span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-slate-300 md:text-xl">
      A personal chronicle &mdash; from the very beginning to where I stand today.
    </p>
    <p class="mt-3 max-w-2xl text-sm text-slate-400">
      Explore my life sections below, or ask the chatbot anything about my journey.
    </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href={`${import.meta.env.BASE_URL}journey`} class="btn-primary">Read the Journey</a>
      <a href="#timeline" class="btn-secondary">View Timeline</a>
    </div>
  </section>

  <div id="timeline">
    <Timeline sections={sorted} />
  </div>

  <ChatWidget slot="chat-widget" />
</BaseLayout>
