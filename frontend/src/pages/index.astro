---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import Globe from '../components/Globe.astro';
import ChatWidget from '../components/ChatWidget.astro';
import { getCollection, render } from 'astro:content';

const sections = await getCollection('journey');
const sorted = sections.sort((a, b) => a.data.order - b.data.order);

const FEATURED_IDS = ['10-thoughts-motivations', '08-networth', '09-ambitions'] as const;
const featured = FEATURED_IDS
  .map((id) => sorted.find((s) => s.id === id))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));

const rendered = await Promise.all(
  sorted.map(async (entry) => ({ entry, Content: (await render(entry)).Content })),
);
---
<BaseLayout title="Home">
  <section class="pt-4 pb-6 md:pt-8 md:pb-8">
    <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,420px)] lg:gap-16">
      <div>
        <h1 class="text-[2.25rem] font-bold leading-tight tracking-tight md:text-[3.375rem]">
          <span class="text-white">naa-</span><span class="bg-gradient-to-r from-accent to-accent-2 bg-clip-text text-transparent">JourneyS</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-slate-300 md:text-xl">
          A personal chronicle &mdash; from the very beginning to where I stand today.
        </p>
        <p class="mt-3 max-w-2xl text-sm text-slate-400">
          Click any milestone on the timeline to read that section below.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="#timeline" class="btn-primary">View Timeline</a>
          <a href="#section-01-early-life" class="btn-secondary">Start Reading</a>
        </div>
      </div>
      <div class="hidden lg:block">
        <Globe />
      </div>
    </div>
  </section>

  <section class="mb-6 grid gap-4 sm:grid-cols-3">
    {featured.map((s) => (
      <a
        href={`#section-${s.id}`}
        class="group relative overflow-hidden rounded-xl border border-border/50 bg-surface-dark/60 p-4 transition-all hover:-translate-y-0.5 hover:border-accent/60 hover:bg-surface-dark/80 hover:shadow-[0_8px_28px_rgba(34,211,238,0.18)] dark:border-slate-700/50"
      >
        <div class="flex items-start gap-3">
          <span class="text-2xl leading-none">{s.data.title.split(' ')[0]}</span>
          <div class="min-w-0">
            <h3 class="text-sm font-semibold text-text dark:text-text-dark group-hover:text-accent">
              {s.data.title.split(' ').slice(1).join(' ')}
            </h3>
            <p class="mt-1 text-xs leading-snug text-text-muted dark:text-slate-400">
              {s.data.summary}
            </p>
          </div>
        </div>
        <span class="absolute right-3 top-3 text-xs text-text-muted opacity-0 transition-opacity group-hover:opacity-100 dark:text-slate-500">↓</span>
      </a>
    ))}
  </section>

  <div id="timeline">
    <Timeline sections={sorted} />
  </div>

  <div class="mt-12 lg:grid lg:grid-cols-[minmax(0,1fr)_220px] lg:gap-10">
    <section class="space-y-0">
      {rendered.map(({ entry, Content }) => (
        <article
          id={`section-${entry.id}`}
          class="scroll-mt-32 border-t border-border/40 dark:border-slate-700/40"
        >
          <header class="sticky top-[57px] z-20 -mx-6 border-b border-border/40 bg-surface-dark/85 px-6 py-4 backdrop-blur dark:border-slate-700/40 md:-mx-10 md:px-10">
            <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-primary/80 dark:text-accent/80">
              {entry.data.category}
            </p>
            <h2 class="mt-1 text-2xl font-bold text-primary dark:text-accent md:text-3xl">
              {entry.data.title}
            </h2>
            {entry.data.subtitle && (
              <p class="mt-0.5 text-sm italic text-text-muted dark:text-slate-400">
                ({entry.data.subtitle})
              </p>
            )}
            <p class="mt-1 text-sm leading-tight text-text-muted dark:text-slate-400">
              {entry.data.yearRange}
              <span class="mx-2 text-slate-600">·</span>
              {entry.data.dateRange}
              <span class="mx-2 text-slate-600">·</span>
              <span class="font-medium text-primary/80 dark:text-accent/80">{entry.data.place}</span>
            </p>
          </header>
          <div class="journey-content px-1 py-8 md:px-2">
            <Content />
          </div>
        </article>
      ))}
    </section>

    <aside class="hidden lg:block">
      <nav class="sticky top-32 max-h-[calc(100vh-9rem)] overflow-y-auto pr-2" aria-label="Section navigator">
        <p class="mb-3 text-[10px] font-semibold uppercase tracking-[0.18em] text-text-muted dark:text-slate-500">
          On this page
        </p>
        <ol class="space-y-1 border-l border-border/50 dark:border-slate-700/60">
          {sorted.map((s) => (
            <li>
              <a
                href={`#section-${s.id}`}
                data-toc-id={s.id}
                class="toc-link -ml-px block border-l-2 border-transparent py-1.5 pl-3 pr-2 text-sm text-text-muted transition-colors hover:border-accent hover:text-accent dark:text-slate-400"
              >
                {s.data.title}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </aside>
  </div>

  <ChatWidget slot="chat-widget" />
</BaseLayout>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const sections = Array.from(document.querySelectorAll<HTMLElement>('article[id^="section-"]'));
  if (links.length && sections.length) {
    const setActive = (id: string) => {
      links.forEach((l) => {
        const isActive = l.dataset.tocId === id;
        l.classList.toggle('border-accent', isActive);
        l.classList.toggle('text-accent', isActive);
        l.classList.toggle('font-medium', isActive);
      });
    };
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible) {
          const id = visible.target.id.replace(/^section-/, '');
          setActive(id);
        }
      },
      { rootMargin: '-30% 0px -60% 0px', threshold: [0, 0.25, 0.5, 1] },
    );
    sections.forEach((s) => observer.observe(s));
  }
</script>

<style is:global>
  .journey-content { color: rgb(226 232 240); line-height: 1.7; }
  .journey-content h2 { font-size: 1.5rem; font-weight: 700; color: rgb(34 211 238); margin-top: 1.5rem; margin-bottom: 0.75rem; }
  .journey-content h3 { font-size: 1.25rem; font-weight: 600; color: rgb(56 189 248); margin-top: 1.25rem; margin-bottom: 0.5rem; }
  .journey-content p { margin-bottom: 1rem; }
  .journey-content ul, .journey-content ol { margin: 0.75rem 0 1rem 1.5rem; }
  .journey-content li { margin-bottom: 0.35rem; }
  .journey-content strong { color: rgb(241 245 249); }
  .journey-content a { color: rgb(34 211 238); text-decoration: underline; text-underline-offset: 3px; }
  .journey-content code { background: rgb(15 23 42); padding: 0.1rem 0.35rem; border-radius: 4px; font-size: 0.9em; }
</style>
