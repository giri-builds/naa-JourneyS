---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A personal life journey — from birth to present" } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | naa-JourneyS</title>
  </head>
  <body class="min-h-screen bg-surface text-text dark:bg-surface-dark dark:text-text-dark">
    <header class="sticky top-0 z-40 border-b border-border bg-white/80 backdrop-blur dark:border-slate-700 dark:bg-slate-900/80">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <a href={base} class="text-xl font-bold text-primary dark:text-accent">naa-JourneyS</a>
        <div class="hidden gap-6 md:flex">
          <a href={base} class="text-sm hover:text-primary dark:hover:text-accent">Home</a>
          <a href={`${base}journey`} class="text-sm hover:text-primary dark:hover:text-accent">Journey</a>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>

    <footer class="border-t border-border py-6 text-center text-sm text-text-muted dark:border-slate-700">
      <p>&copy; {new Date().getFullYear()} naa-JourneyS. Built with Astro.</p>
    </footer>

    <slot name="chat-widget" />
  </body>
</html>
