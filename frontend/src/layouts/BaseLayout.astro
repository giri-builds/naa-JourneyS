---
import '../styles/global.css';
import SocialLinks from '../components/SocialLinks.astro';
import GlobeBackground from '../components/GlobeBackground.astro';
import ActivityCard from '../components/ActivityCard.astro';
import { interests } from '../data/profile';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A personal life journey — from birth to present" } = Astro.props;
const base = import.meta.env.BASE_URL;
const marqueeItems = [...interests, ...interests];
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | naa-JourneyS</title>
    <style>
      html { background-color: #020617; }
      body { background-color: transparent !important; }
    </style>
  </head>
  <body class="min-h-screen text-text dark:text-text-dark">
    <GlobeBackground />
    <header class="sticky top-0 z-40 border-b border-border bg-white/80 backdrop-blur dark:border-slate-700 dark:bg-slate-900/70">
      <nav class="mx-auto flex max-w-[1500px] items-center gap-6 px-6 py-3 md:px-10">
        <a href={base} class="shrink-0 text-xl font-bold text-primary dark:text-accent">naa-JourneyS</a>
        <div class="marquee hidden flex-1 overflow-hidden md:block" aria-hidden="true">
          <div class="marquee-track">
            {marqueeItems.map((item) => (
              <span class="marquee-item">{item}</span>
            ))}
          </div>
        </div>
        <div class="hidden shrink-0 gap-6 md:flex">
          <a href={base} class="text-sm hover:text-primary dark:hover:text-accent">Home</a>
          <a href={`${base}journey`} class="text-sm hover:text-primary dark:hover:text-accent">Journey</a>
        </div>
      </nav>
    </header>

    <main class="relative z-10 mx-auto max-w-[1500px] px-6 pt-3 pb-8 md:px-10 md:pt-4">
      <SocialLinks />
      <div class="mb-3 grid items-center gap-4 md:mb-4 md:grid-cols-[1fr_auto_1fr]">
        <div class="flex justify-center md:justify-start">
          <ActivityCard variant="status" />
        </div>
        <ActivityCard variant="identity" />
        <div class="hidden md:block"></div>
      </div>
      <slot />
    </main>

    <footer class="relative z-10 border-t border-border py-6 text-center text-sm text-text-muted dark:border-slate-700">
      <p>&copy; {new Date().getFullYear()} naa-JourneyS. Built with Astro.</p>
    </footer>

    <slot name="chat-widget" />
  </body>
</html>

<style is:global>
  .marquee {
    mask-image: linear-gradient(to right, transparent 0, #000 10%, #000 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0, #000 10%, #000 90%, transparent 100%);
  }
  .marquee-track {
    display: inline-flex;
    gap: 2.25rem;
    white-space: nowrap;
    will-change: transform;
    animation: marquee-scroll 60s linear infinite;
  }
  .marquee-item {
    font-size: 0.78rem;
    letter-spacing: 0.02em;
    color: #94a3b8;
    flex-shrink: 0;
  }
  .marquee:hover .marquee-track { animation-play-state: paused; }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
