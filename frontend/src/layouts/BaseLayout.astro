---
import '../styles/global.css';
import SocialLinks from '../components/SocialLinks.astro';
import GlobeBackground from '../components/GlobeBackground.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A personal life journey — from birth to present" } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | naa-JourneyS</title>
    <style>
      html { background-color: #020617; }
      body { background-color: transparent !important; }
    </style>
  </head>
  <body class="min-h-screen text-text dark:text-text-dark">
    <GlobeBackground />
    <header class="sticky top-0 z-40 border-b border-border bg-white/80 backdrop-blur dark:border-slate-700 dark:bg-slate-900/70">
      <nav class="mx-auto flex max-w-[1500px] items-center justify-between px-6 py-3 md:px-10">
        <a href={base} class="text-xl font-bold text-primary dark:text-accent">naa-JourneyS</a>
        <div class="hidden gap-6 md:flex">
          <a href={base} class="text-sm hover:text-primary dark:hover:text-accent">Home</a>
          <a href={`${base}journey`} class="text-sm hover:text-primary dark:hover:text-accent">Journey</a>
        </div>
      </nav>
    </header>

    <main class="relative z-10 mx-auto max-w-[1500px] px-6 py-8 md:px-10">
      <SocialLinks />
      <slot />
    </main>

    <footer class="relative z-10 border-t border-border py-6 text-center text-sm text-text-muted dark:border-slate-700">
      <p>&copy; {new Date().getFullYear()} naa-JourneyS. Built with Astro.</p>
    </footer>

    <slot name="chat-widget" />
  </body>
</html>
