---
import { profile, schedule } from '../data/profile';
---
<div class="activity-card" role="status" aria-live="polite">
  <p class="card-name">{profile.name}</p>
  <p class="card-place">📍 {profile.place}</p>
  <p class="card-when">
    <span aria-hidden="true">🗓️</span>
    <span id="card-clock">--</span>
  </p>
  <p class="card-status">
    <span class="card-pulse" aria-hidden="true"></span>
    <span class="card-status-prefix">Current Status:</span>
    <span class="card-status-value" id="card-activity">Loading…</span>
  </p>
</div>

<script define:vars={{ schedule, timezone: profile.timezone }}>
  function toMinutes(hhmm) {
    const [h, m] = hhmm.split(':').map(Number);
    return h * 60 + m;
  }
  function inSlot(now, from, to) {
    const f = toMinutes(from);
    const t = toMinutes(to);
    if (f === t) return false;
    if (f < t) return now >= f && now < t;
    return now >= f || now < t;
  }

  const dateFmt = new Intl.DateTimeFormat('en-GB', {
    weekday: 'short',
    day: 'numeric',
    month: 'short',
    timeZone: timezone,
  });
  const timeFmt = new Intl.DateTimeFormat('en-US', {
    hour: 'numeric',
    minute: '2-digit',
    hour12: true,
    timeZone: timezone,
  });
  const slotFmt = new Intl.DateTimeFormat('en-GB', {
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
    timeZone: timezone,
  });

  function nowMinutes(date) {
    const parts = slotFmt.formatToParts(date);
    const hh = parts.find((p) => p.type === 'hour').value;
    const mm = parts.find((p) => p.type === 'minute').value;
    return toMinutes(`${hh}:${mm}`);
  }

  const clockEl = document.getElementById('card-clock');
  const actEl = document.getElementById('card-activity');
  function tick() {
    const now = new Date();
    const min = nowMinutes(now);
    const slot = schedule.find((s) => inSlot(min, s.from, s.to));
    if (clockEl) clockEl.textContent = `${dateFmt.format(now)}, ${timeFmt.format(now)} IST`;
    if (actEl) actEl.textContent = slot ? slot.label : '✨ Free time';
  }
  tick();
  setInterval(tick, 30_000);
</script>

<style>
  .activity-card {
    width: min(92%, 360px);
    margin: 0 auto;
    padding: 0.7rem 1rem;
    border-radius: 0.85rem;
    background: rgba(2, 6, 23, 0.55);
    border: 1px solid rgba(34, 211, 238, 0.22);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35), 0 0 24px rgba(34, 211, 238, 0.08);
  }
  .card-name {
    font-size: 1rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: 0.01em;
  }
  .card-place {
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: #94a3b8;
  }
  .card-when {
    margin-top: 0.15rem;
    font-size: 0.75rem;
    color: #94a3b8;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    justify-content: center;
  }
  .card-dot { color: #475569; }
  .card-status {
    margin-top: 0.45rem;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .card-status-prefix {
    color: #94a3b8;
    font-weight: 500;
  }
  .card-status-value {
    color: #22d3ee;
    font-weight: 600;
  }
  .card-pulse {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: #22d3ee;
    box-shadow: 0 0 8px rgba(34, 211, 238, 0.8);
    animation: card-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes card-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.8); }
  }
</style>
