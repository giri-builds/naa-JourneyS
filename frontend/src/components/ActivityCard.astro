---
import { profile, schedule } from '../data/profile';

interface Props {
  variant?: 'identity' | 'status';
}
const { variant = 'identity' } = Astro.props;
const clockId = `card-clock-${variant}`;
const activityId = `card-activity-${variant}`;
---
{variant === 'identity' && (
  <div class="activity-card" role="status" aria-live="polite">
    <p class="card-name">{profile.name}</p>
    <p class="card-place">📍 {profile.place}</p>
    <p class="card-when">
      <span aria-hidden="true">🗓️</span>
      <span id={clockId}>--</span>
    </p>
  </div>
)}

{variant === 'status' && (
  <div class="status-card" role="status" aria-live="polite">
    <span class="status-pulse" aria-hidden="true"></span>
    <div class="status-text">
      <span class="status-prefix">Current Status</span>
      <span class="status-value" id={activityId}>Loading…</span>
    </div>
  </div>
)}

<script define:vars={{ schedule, timezone: profile.timezone, clockId, activityId }}>
  function toMinutes(hhmm) {
    const [h, m] = hhmm.split(':').map(Number);
    return h * 60 + m;
  }
  function inSlot(now, from, to) {
    const f = toMinutes(from);
    const t = toMinutes(to);
    if (f === t) return false;
    if (f < t) return now >= f && now < t;
    return now >= f || now < t;
  }

  const dateFmt = new Intl.DateTimeFormat('en-GB', {
    weekday: 'short',
    day: 'numeric',
    month: 'short',
    timeZone: timezone,
  });
  const timeFmt = new Intl.DateTimeFormat('en-US', {
    hour: 'numeric',
    minute: '2-digit',
    hour12: true,
    timeZone: timezone,
  });
  const slotFmt = new Intl.DateTimeFormat('en-GB', {
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
    timeZone: timezone,
  });

  function nowMinutes(date) {
    const parts = slotFmt.formatToParts(date);
    const hh = parts.find((p) => p.type === 'hour').value;
    const mm = parts.find((p) => p.type === 'minute').value;
    return toMinutes(`${hh}:${mm}`);
  }

  const clockEl = document.getElementById(clockId);
  const actEl = document.getElementById(activityId);
  function tick() {
    const now = new Date();
    if (clockEl) clockEl.textContent = `${dateFmt.format(now)}, ${timeFmt.format(now)} IST`;
    if (actEl) {
      const slot = schedule.find((s) => inSlot(nowMinutes(now), s.from, s.to));
      actEl.textContent = slot ? slot.label : '✨ Free time';
    }
  }
  tick();
  setInterval(tick, 30_000);
</script>

<style>
  .activity-card {
    width: max-content;
    max-width: min(92vw, 480px);
    margin: 0 auto;
    padding: 0.7rem 1.2rem;
    border-radius: 0.85rem;
    background: rgba(2, 6, 23, 0.55);
    border: 1px solid rgba(34, 211, 238, 0.22);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    text-align: center;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35), 0 0 24px rgba(34, 211, 238, 0.08);
  }
  .card-name {
    font-size: 1rem;
    font-weight: 700;
    color: #f1f5f9;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .card-place {
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: #94a3b8;
    white-space: nowrap;
  }
  .card-when {
    margin-top: 0.15rem;
    font-size: 0.75rem;
    color: #94a3b8;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    justify-content: center;
    white-space: nowrap;
  }

  .status-card {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1rem 1.4rem;
    border-radius: 0.95rem;
    background: rgba(2, 6, 23, 0.6);
    border: 1px solid rgba(34, 211, 238, 0.3);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 10px 36px rgba(0, 0, 0, 0.4), 0 0 28px rgba(34, 211, 238, 0.12);
  }
  .status-pulse {
    width: 14px;
    height: 14px;
    border-radius: 999px;
    background: #22d3ee;
    box-shadow: 0 0 14px rgba(34, 211, 238, 0.9);
    animation: card-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  .status-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .status-prefix {
    font-size: 0.85rem;
    font-weight: 500;
    color: #94a3b8;
    letter-spacing: 0.02em;
  }
  .status-value {
    font-size: 1.6rem;
    font-weight: 700;
    color: #22d3ee;
    margin-top: 0.15rem;
  }

  @keyframes card-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.8); }
  }
</style>
