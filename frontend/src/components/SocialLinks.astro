---
const links = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/dastagiri-vadapalli-ai-engineer',
  },
  { label: 'GitHub', href: 'https://github.com/giri-builds' },
  { label: 'YouTube', href: 'https://www.youtube.com/@naaJourneyS' },
  { label: 'Instagram', href: 'https://www.instagram.com/_naa_journeys_' },
  { label: 'X', href: 'https://x.com/giri_builds' },
  { label: 'Email', href: 'mailto:dastagirivadapalli@gmail.com' },
  { label: 'Phone', href: 'tel:+919010201623' },
];
---
