          <path d="M1.5 4h21A1.5 1.5 0 0 1 24 5.5v13a1.5 1.5 0 0 1-1.5 1.5h-21A1.5 1.5 0 0 1 0 18.5v-13A1.5 1.5 0 0 1 1.5 4zm.84 2L12 12.13 21.66 6H2.34zM22 7.27l-9.47 5.92a1 1 0 0 1-1.06 0L2 7.27V18h20V7.27z" />
