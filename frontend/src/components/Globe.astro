---
---
<div class="globe-stage" aria-hidden="true">
  <canvas id="cobe-globe" class="globe-canvas"></canvas>
</div>

<script>
  import createGlobe from 'cobe';

  const canvas = document.getElementById('cobe-globe') as HTMLCanvasElement | null;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas) {
    let phi = 0;
    const size = 950;
    canvas.width = size;
    canvas.height = size;

    createGlobe(canvas, {
      devicePixelRatio: 2,
      width: size,
      height: size,
      phi: 0,
      theta: 0.25,
      dark: 1,
      diffuse: 1.4,
      mapSamples: 16000,
      mapBrightness: 6.5,
      baseColor: [0.18, 0.45, 0.6],
      markerColor: [0.13, 0.83, 0.93],
      glowColor: [0.18, 0.78, 1.1],
      markers: [
        { location: [14.4673, 78.8242], size: 0.06 },
        { location: [17.385, 78.4867], size: 0.07 },
        { location: [13.0827, 80.2707], size: 0.05 },
      ],
      onRender: (state) => {
        state.phi = phi;
        if (!reduceMotion) phi += 0.004;
      },
    });
  }
</script>

<style>
  .globe-stage {
    width: 100%;
    max-width: 525px;
    aspect-ratio: 1;
    margin: 0 auto;
    position: relative;
  }

  .globe-stage::before {
    content: '';
    position: absolute;
    inset: -8%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.18) 0%, rgba(34, 211, 238, 0.05) 45%, transparent 70%);
    filter: blur(28px);
    pointer-events: none;
  }

  .globe-canvas {
    width: 100%;
    height: 100%;
    display: block;
    contain: layout paint size;
    cursor: grab;
  }
</style>
