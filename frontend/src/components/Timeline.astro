---
const base = import.meta.env.BASE_URL;

interface Section {
  id: string;
  data: {
    title: string;
    subtitle?: string;
    order: number;
    dateRange: string;
    yearRange: string;
    place: string;
    summary: string;
    category: string;
    labelSide?: 'above' | 'below';
    labelOffset?: number;
    hideFromTimeline?: boolean;
  };
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;

const BIRTH_YEAR = 1989;
const CURRENT_YEAR = new Date().getFullYear();

function parseStartYear(yearRange: string): number | null {
  const m = yearRange.match(/(\d{4})/);
  return m ? Number(m[1]) : null;
}

function parseStartAge(dateRange: string): number | null {
  if (/birth/i.test(dateRange)) return 0;
  const m = dateRange.match(/Age\s+(\d+)/i);
  return m ? Number(m[1]) : null;
}

const inOrder = sections
  .filter((s) => !s.data.hideFromTimeline)
  .sort((a, b) => a.data.order - b.data.order);

interface Placed extends Section {
  year: number;
  age: number;
}

const placed: Placed[] = [];
const timeless: Section[] = [];
for (const s of inOrder) {
  const year = parseStartYear(s.data.yearRange);
  const age = parseStartAge(s.data.dateRange);
  if (year !== null && age !== null) {
    placed.push({ ...s, year, age });
  } else {
    timeless.push(s);
  }
}

const W = 1800;
const H = 800;
const padL = 110;
const padR = 60;
const padTop = 200;
const padBottom = 200;
const plotW = W - padL - padR;
const plotH = H - padTop - padBottom;

const minYear = BIRTH_YEAR;
const placedMaxYear = placed.reduce((m, p) => Math.max(m, p.year), CURRENT_YEAR);
const maxYear = Math.max(CURRENT_YEAR + 2, Math.ceil(placedMaxYear / 5) * 5);

const minAge = 0;
const placedMaxAge = placed.reduce((m, p) => Math.max(m, p.age), 0);
const maxAge = Math.max(35, Math.ceil((placedMaxAge + 2) / 5) * 5);

const xTicks: number[] = [];
for (let y = 1990; y <= maxYear; y += 5) xTicks.push(y);

const yTicks: number[] = [];
for (let a = 0; a <= maxAge; a += 5) yTicks.push(a);

const xFor = (year: number) => padL + ((year - minYear) / (maxYear - minYear)) * plotW;
const yFor = (age: number) => padTop + plotH - ((age - minAge) / (maxAge - minAge)) * plotH;

interface Pt extends Placed { px: number; py: number }
const pts: Pt[] = placed.map((p) => ({ ...p, px: xFor(p.year), py: yFor(p.age) }));

function roadPath(items: Pt[]): string {
  if (items.length < 2) return '';
  const d: string[] = [`M ${items[0].px.toFixed(1)} ${items[0].py.toFixed(1)}`];
  for (let i = 0; i < items.length - 1; i++) {
    const a = items[i];
    const b = items[i + 1];
    const dx = b.px - a.px;
    const dy = b.py - a.py;
    const len = Math.hypot(dx, dy) || 1;
    const nx = -dy / len;
    const ny = dx / len;
    // Don't bend short segments — clusters were producing loops in the road.
    const bend = len < 90 ? 0 : (i % 2 === 0 ? 1 : -1) * Math.min(35, len * 0.15);
    const c1x = a.px + dx * 0.33 + nx * bend;
    const c1y = a.py + dy * 0.33 + ny * bend;
    const c2x = a.px + dx * 0.67 + nx * bend;
    const c2y = a.py + dy * 0.67 + ny * bend;
    d.push(
      `C ${c1x.toFixed(1)} ${c1y.toFixed(1)}, ${c2x.toFixed(1)} ${c2y.toFixed(1)}, ${b.px.toFixed(1)} ${b.py.toFixed(1)}`,
    );
  }
  return d.join(' ');
}

const pathD = roadPath(pts);
---

<section class="pt-2 pb-6">
  <h2 class="mb-1 text-center text-2xl font-bold text-primary dark:text-accent">Life Timeline</h2>
  <p class="mb-3 text-center text-xs text-text-muted dark:text-slate-500">
    Click any milestone to read the section below
  </p>

  <div class="relative -mx-4 overflow-x-auto px-4 md:mx-0 md:px-0">
    <div class="relative mx-auto" style={`width: ${W}px; height: ${H}px; min-width: ${W}px;`}>
      <svg viewBox={`0 0 ${W} ${H}`} class="absolute inset-0 h-full w-full" aria-hidden="true">
        <defs>
          <linearGradient id="road-edge" x1="0" y1="1" x2="1" y2="0">
            <stop offset="0%" stop-color="#64748b" stop-opacity="0.55" />
            <stop offset="100%" stop-color="#22d3ee" stop-opacity="0.85" />
          </linearGradient>
          <linearGradient id="road-body" x1="0" y1="1" x2="1" y2="0">
            <stop offset="0%" stop-color="#1e293b" />
            <stop offset="100%" stop-color="#0f172a" />
          </linearGradient>
        </defs>

        {pts.length >= 2 && (
          <>
            <path d={pathD} fill="none" stroke="url(#road-edge)" stroke-width="34" stroke-linecap="round" stroke-linejoin="round" />
            <path d={pathD} fill="none" stroke="url(#road-body)" stroke-width="22" stroke-linecap="round" stroke-linejoin="round" />
            <path d={pathD} fill="none" stroke="#facc15" stroke-width="2" stroke-dasharray="14 12" stroke-linecap="round" opacity="0.85" />
          </>
        )}

        {xTicks.map((year) => (
          <g>
            <circle cx={xFor(year)} cy={padTop + plotH + 18} r="3" fill="#22d3ee" opacity="0.85" />
            <text x={xFor(year)} y={padTop + plotH + 38} text-anchor="middle" font-size="11" fill="#94a3b8" font-family="ui-sans-serif, system-ui, sans-serif">
              {year}
            </text>
          </g>
        ))}

        {yTicks.map((age) => (
          <g>
            <circle cx={padL - 22} cy={yFor(age)} r="3" fill="#22d3ee" opacity="0.85" />
            <text x={padL - 32} y={yFor(age) + 4} text-anchor="end" font-size="11" fill="#94a3b8" font-family="ui-sans-serif, system-ui, sans-serif">
              {age}
            </text>
          </g>
        ))}

        <text x={padL - 50} y={padTop - 18} text-anchor="start" font-size="10" fill="#64748b" font-family="ui-sans-serif, system-ui, sans-serif" letter-spacing="1">
          AGE ↑
        </text>
        <text x={padL + plotW + 20} y={padTop + plotH + 38} text-anchor="end" font-size="10" fill="#64748b" font-family="ui-sans-serif, system-ui, sans-serif" letter-spacing="1">
          YEAR →
        </text>
      </svg>

      {pts.map((p, i) => {
        // 4-lane staggering: alternate above/below AND alternate near/far.
        // Pattern: above-far, below-near, above-near, below-far, repeat.
        // Adjacent dots always land on opposite sides (no horizontal collide),
        // and same-side dots (i, i+2) land at different distances (no stack).
        const lane = i % 4;
        const fallbackSide: 'above' | 'below' =
          lane === 0 || lane === 2 ? 'above' : 'below';
        const fallbackOffset = lane === 0 ? 130 : lane === 1 ? 64 : lane === 2 ? 64 : 130;
        // Per-entry overrides (from markdown frontmatter) win over the fallback.
        const side = p.data.labelSide ?? fallbackSide;
        const offset = p.data.labelOffset ?? fallbackOffset;
        const labelStyle = side === 'above' ? `bottom: ${offset}px;` : `top: ${offset}px;`;
        // Popover mirrors the label side: if label is above, popover sits below.
        const popoverStyle = side === 'above' ? 'top: 40px;' : 'bottom: 40px;';
        const LABEL_W = 144;
        const isNearLeft = p.px - LABEL_W / 2 < padL;
        const isNearRight = p.px + LABEL_W / 2 > padL + plotW;
        const labelAlign = isNearLeft
          ? 'left-0 translate-x-0 text-left'
          : isNearRight
          ? 'right-0 translate-x-0 text-right'
          : 'left-1/2 -translate-x-1/2 text-center';
        const popoverAlign = isNearLeft
          ? 'left-0 translate-x-0'
          : isNearRight
          ? 'right-0 translate-x-0'
          : 'left-1/2 -translate-x-1/2';
        return (
          <a
            href={`${base}#section-${p.id}`}
            class="group absolute z-10 inline-block hover:z-30 focus:z-30"
            style={`left: ${p.px}px; top: ${p.py}px; transform: translate(-50%, -50%);`}
          >
            <span class="block h-4 w-4 rounded-full border-2 border-white bg-primary shadow-[0_0_18px_rgba(34,211,238,0.65)] transition-transform group-hover:scale-125 dark:border-slate-900 dark:bg-accent"></span>

            <div class={`absolute w-36 ${labelAlign}`} style={labelStyle}>
              <p class="text-sm font-semibold leading-tight text-text dark:text-text-dark group-hover:text-primary dark:group-hover:text-accent">
                {p.data.title}
              </p>
              {p.data.subtitle && (
                <p class="text-[11px] italic leading-tight text-text-muted dark:text-slate-400">
                  ({p.data.subtitle})
                </p>
              )}
              <p class="mt-0.5 text-[11px] leading-tight text-text-muted dark:text-slate-400">{p.data.yearRange}</p>
              <p class="text-[11px] leading-tight font-medium text-primary/80 dark:text-accent/80">{p.data.place}</p>
            </div>

            <div
              class={`pointer-events-none absolute w-60 rounded-lg border border-border bg-white p-3 text-left text-xs leading-snug text-text-muted opacity-0 shadow-xl transition-opacity duration-150 group-hover:opacity-100 group-focus:opacity-100 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 ${popoverAlign}`}
              style={popoverStyle}
            >
              <p class="mb-1 text-[10px] font-semibold uppercase tracking-wider text-primary dark:text-accent">
                {p.data.category}
              </p>
              {p.data.summary}
            </div>
          </a>
        );
      })}
    </div>
  </div>

  {timeless.length > 0 && (
    <div class="mx-auto mt-4 flex max-w-3xl flex-wrap justify-center gap-3">
      {timeless.map((s) => (
        <a
          href={`${base}#section-${s.id}`}
          class="rounded-full border border-border bg-white/5 px-4 py-1.5 text-xs text-text-muted transition-colors hover:border-accent hover:text-accent dark:border-slate-700"
        >
          {s.data.title} · {s.data.yearRange}
        </a>
      ))}
    </div>
  )}
</section>
