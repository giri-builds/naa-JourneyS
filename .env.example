# naa-JourneyS environment variables

# LLM Provider: groq | claude | openai | ollama
LLM_PROVIDER=groq

# Groq (default, free tier)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace (embeddings, free tier)
HF_API_KEY=your_hf_api_key_here

# Claude (optional, switchable)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenAI (optional, switchable)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# Ollama (optional, local demo)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
